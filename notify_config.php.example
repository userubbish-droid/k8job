<?php
/**
 * 待审核流水 + 余额阈值 Telegram 通知（与本文件同目录的 config.php 会自动 include）
 * 复制本文件为 notify_config.php（勿提交 Git），取消注释并填写。
 * 勿把整份赋值包在 if (!defined('NOTIFY_CONFIG_LOADED')) { ... } 里（旧版 config 曾误先 define 导致永不执行）；顶层直接写 $… 变量即可。
 *
 * === Telegram ===
 * 1. @BotFather /newbot 取得 BOT_TOKEN
 * 2. 先对 Bot 私聊发一条消息
 * 3. 浏览器打开 https://api.telegram.org/bot<TOKEN>/getUpdates 取 chat.id 作为 CHAT_ID
 */
$NOTIFY_TELEGRAM_BOT_TOKEN = ''; // 必填
$NOTIFY_TELEGRAM_CHAT_ID  = '';  // 必填，多为数字字符串
$NOTIFY_BASE_URL = '';           // 选填：待审核消息里审核链接前缀，如 https://你的域名.com

// === PG 专用 Bot === 请复制 PG_notify_config.php.example 为 PG_notify_config.php 并填写 token（与 notify 分开，多域名好维护）
// 若群里发 +100… 机器人完全没反应：在 @BotFather 对该 bot 发 /setprivacy，选 Disable。
// 环境变量兜底：Hostinger 里设 PG_TELEGRAM_BOT_TOKEN（config.php 会读 getenv / $_SERVER / $_ENV）。

